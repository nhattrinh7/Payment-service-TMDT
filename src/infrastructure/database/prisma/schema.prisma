generator client {
  provider = "prisma-client-js"
}

// prisma tự động đọc file .env dù cho chưa cài .dotenv, nhưng chỉ đọc được giá trị 
// trong env khi prisma đã start lên, những chỗ chưa start thì chịu
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") 
}

// trường code của PaymentTransaction sẽ truyền về paymentCode (vì mình đặt nội dung chuyển khoản là paymentCode)
// nên khi nhận webhook sẽ tự có paymentCode để biết phải cập nhật Payment nào
model Payment {
  id          String        @id @default(uuid()) @db.Uuid
  paymentCode String        @unique @db.VarChar(30) @map("payment_code")
  userId      String        @db.Uuid @map("user_id")
  amount      Int           @default(0)
  sagaId      String?       @db.Uuid @map("saga_id")
  status      PaymentStatus
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCESS 
  FAILED
}

model PaymentTransaction {
  id                 String   @id @default(uuid()) @db.Uuid
  gateway            String   @db.VarChar(100)
  transactionDate    DateTime @default(now()) @map("transaction_date")

  accountNumber      String?  @db.VarChar(100) @map("account_number")
  subAccount         String?  @db.VarChar(250) @map("sub_account")

  amountIn           Int      @default(0)      @map("amount_in")
  amountOut          Int      @default(0)      @map("amount_out")
  accumulated        Int      @default(0)

  code               String?  @db.VarChar(250)
  transactionContent String?  @db.Text         @map("transaction_content")
  referenceNumber    String?  @db.VarChar(255) @map("reference_number")
  body               String?  @db.Text

  createdAt          DateTime @default(now())  @map("created_at")

  @@map("payment_transactions")
}


